// We only compile the 64-bit integer range compulation for value types
// of long, unsigned long, long long, and unsigned long log.  All others
// reuse the double-precision vtkDataArray::GetRange version, since they
// won't lose precision.

#define VTK_AOS_DATA_ARRAY_TEMPLATE_INSTANTIATING
#include "vtkAOSDataArrayTemplate.h"
#define VTK_SOA_DATA_ARRAY_TEMPLATE_INSTANTIATING
#include "vtkSOADataArrayTemplate.h"
#define VTK_SCALED_SOA_DATA_ARRAY_TEMPLATE_INSTANTIATING
#include "vtkScaledSOADataArrayTemplate.h"
#define VTK_AFFINE_ARRAY_INSTANTIATING
#include "vtkAffineArray.h"
#define VTK_COMPOSITE_ARRAY_INSTANTIATING
#include "vtkCompositeArray.h"
#define VTK_CONSTANT_ARRAY_INSTANTIATING
#include "vtkConstantArray.h"
#define VTK_INDEXED_ARRAY_INSTANTIATING
#include "vtkIndexedArray.h"
#define VTK_STD_FUNCTION_ARRAY_INSTANTIATING
#include "vtkStdFunctionArray.h"
#define VTK_STRIDED_ARRAY_INSTANTIATING
#include "vtkStridedArray.h"
#define VTK_STRUCTURED_POINT_ARRAY_INSTANTIATING
#include "vtkStructuredPointArray.h"
#include "vtkDataArrayPrivate.txx"

VTK_AOS_DATA_ARRAY_TEMPLATE_INSTANTIATE_VALUERANGE(@INSTANTIATION_VALUE_TYPE@)
VTK_SOA_DATA_ARRAY_TEMPLATE_INSTANTIATE_VALUERANGE(@INSTANTIATION_VALUE_TYPE@)
VTK_SCALED_SOA_DATA_ARRAY_TEMPLATE_INSTANTIATE_VALUERANGE(@INSTANTIATION_VALUE_TYPE@)
VTK_AFFINE_ARRAY_INSTANTIATE_VALUERANGE(@INSTANTIATION_VALUE_TYPE@)
VTK_COMPOSITE_ARRAY_INSTANTIATE_VALUERANGE(@INSTANTIATION_VALUE_TYPE@)
VTK_CONSTANT_ARRAY_INSTANTIATE_VALUERANGE(@INSTANTIATION_VALUE_TYPE@)
VTK_INDEXED_ARRAY_INSTANTIATE_VALUERANGE(@INSTANTIATION_VALUE_TYPE@)
VTK_STD_FUNCTION_ARRAY_INSTANTIATE_VALUERANGE(@INSTANTIATION_VALUE_TYPE@)
VTK_STRIDED_ARRAY_INSTANTIATE_VALUERANGE(@INSTANTIATION_VALUE_TYPE@)
VTK_STRUCTURED_POINT_ARRAY_INSTANTIATE_VALUERANGE(@INSTANTIATION_VALUE_TYPE@)
